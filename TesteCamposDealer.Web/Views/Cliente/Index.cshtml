@model TesteCamposDealer.Web.ViewModels.PagedResultViewModel<TesteCamposDealer.Web.ViewModels.ClienteViewModel>
@{
    ViewBag.Title = "Clientes";
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Clientes</h2>
    <a href="@Url.Action("Create")" class="btn btn-primary">Novo Cliente</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>Nome</th>
            <th>Endereço</th>
            <th>Cadastrado em</th>
            <th class="text-center"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model.Data)
        {
            <tr>
                <td>@c.nomeCliente</td>
                <td>@c.endereco</td>
                <td>@c.dthRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                <td class="text-center">
                    <a href="@Url.Action("PorCliente", "Venda", new { idCliente = c.idCliente })" class="btn btn-sm btn-info">Vendas</a>
                    <a href="@Url.Action("Edit", new { id = c.idCliente })" class="btn btn-sm btn-secondary">Editar</a>
                    @using (Html.BeginForm("Delete", "Cliente", new { id = c.idCliente }, FormMethod.Post, new { style = "display:inline" }))
                    {
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Excluir cliente @c.nomeCliente?')">
                            Excluir
                        </button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                </li>
            }
        </ul>
    </nav>
}
