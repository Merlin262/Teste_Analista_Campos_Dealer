@model TesteCamposDealer.Web.ViewModels.VendaFormViewModel
@{
    ViewBag.Title = "Nova Venda";
}

<h2>Nova Venda</h2>

@if (!string.IsNullOrEmpty(Model.Erro))
{
    <div class="alert alert-danger">@Model.Erro</div>
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(m => m.idCliente)
        @Html.DropDownListFor(m => m.idCliente,
            new SelectList(Model.Clientes, "idCliente", "nomeCliente"),
            "-- Selecione --",
            new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.idCliente, "", new { @class = "text-danger" })
    </div>

    <h5 class="mt-3">Itens</h5>
    <div id="itens-container">
        <div class="row mb-2 item-row">
            <div class="col-md-7">
                <select name="Itens[0].idProduto" class="form-control">
                    <option value="">-- Produto --</option>
                    @foreach (var p in Model.Produtos)
                    {
                        <option value="@p.idProduto">@p.dscProduto (@p.vlrProduto.ToString("C"))</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <input type="number" name="Itens[0].quantidade" class="form-control" placeholder="Qtd" min="1" value="1" />
            </div>
            <div class="col-md-2">
                <button type="button" class="btn btn-danger btn-remover">-</button>
            </div>
        </div>
    </div>
    <button type="button" id="btn-add-item" class="btn btn-outline-secondary btn-sm mb-3">+ Adicionar Item</button>

    <div>
        <button type="submit" class="btn btn-primary">Salvar</button>
        <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
    </div>
}

@section Scripts {
    <script>
    var produtosHtml = '@Html.Raw(string.Join("", Model.Produtos.Select(p => $"<option value=\\\"{p.idProduto}\\\">{p.dscProduto} ({p.vlrProduto:C})</option>")))';
    var itemIndex = 1;

    $('#btn-add-item').click(function () {
        var row = '<div class="row mb-2 item-row">' +
            '<div class="col-md-7"><select name="Itens[' + itemIndex + '].idProduto" class="form-control">' +
            '<option value="">-- Produto --</option>' + produtosHtml + '</select></div>' +
            '<div class="col-md-3"><input type="number" name="Itens[' + itemIndex + '].quantidade" class="form-control" placeholder="Qtd" min="1" value="1" /></div>' +
            '<div class="col-md-2"><button type="button" class="btn btn-danger btn-remover">-</button></div></div>';
        $('#itens-container').append(row);
        itemIndex++;
    });

    $(document).on('click', '.btn-remover', function () {
        $(this).closest('.item-row').remove();
    });
    </script>
}
