@model TesteCamposDealer.Web.ViewModels.PagedResultViewModel<TesteCamposDealer.Web.ViewModels.VendaViewModel>
@{
    ViewBag.Title = "Ranking de Vendas";
}

<h2>Ranking de Vendas</h2>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>#</th>
            <th>Cliente</th>
            <th>Valor Total</th>
            <th>Data</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @{ int pos = ((Model.Page - 1) * Model.PageSize) + 1; }
        @foreach (var v in Model.Data)
        {
            <tr>
                <td><strong>@pos</strong></td>
                <td>@v.nomeCliente</td>
                <td>@v.vlrTotal.ToString("C")</td>
                <td>@v.dthRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    <a href="@Url.Action("Details", new { id = v.idVenda })" class="btn btn-sm btn-info">Detalhes</a>
                </td>
            </tr>
            pos++;
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Ranking", new { page = i })">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<a href="@Url.Action("Index")" class="btn btn-outline-secondary">Voltar</a>
